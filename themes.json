{
  "$schema": "https://json-schemastore.org/color-theme",
  "name": "Assistant Taskboard Themes",
  "version": "1.0.0",
  "description": "CSS custom property theme collection. Each theme defines design tokens as CSS variables. Apply by setting each key as a CSS custom property on :root or a container element.",
  "usage": {
    "css": "Set each variable in the theme's 'vars' object as a CSS custom property, e.g. :root { --bg-primary: #FFFFFF; ... }",
    "js": "Object.entries(theme.vars).forEach(([k, v]) => document.documentElement.style.setProperty(k, v));",
    "notes": [
      "Themes with style 'glass' use backdrop-filter: blur(var(--card-blur)) on cards.",
      "Themes with style 'neon' use box-shadow glow effects keyed to --accent.",
      "Themes with style 'brutalist' use zero border-radius and heavy borders.",
      "Themes with style 'gradient' use linear-gradient values for --header-bg and --sidebar-bg.",
      "'darkThemes' array lists which theme IDs should use light-on-dark text and dark scrollbar styling."
    ]
  },
  "darkThemes": ["dark", "midnight", "ocean", "highContrast", "glass", "neon", "nord", "sunset", "grunge", "hacker"],
  "themes": {
